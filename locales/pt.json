  "challenges": {
    "eyebrow": "Barreras operativas",
    "title": "Los retos de una gestión hídrica fragmentada",
    "description": "Muchas autoridades hídricas siguen gestionando licencias y facturación en libros en papel y hojas de cálculo desconectadas. Esa fragmentación genera fricción diaria entre departamentos y dificulta el cumplimiento de la recuperación de costes exigida por ley.",
    "items": [
      {
        "tag": "Registros fragmentados",
        "problem": "Datos de licencias y facturación repartidos entre papel, hojas de cálculo y departamentos sin una visión compartida."
      },
      {
        "tag": "Procedimientos lentos",
        "problem": "Cálculos manuales y tramitación en papel retrasan renovaciones de licencias y el trabajo diario."
      },
      {
        "tag": "Baja recaudación",
        "problem": "Lagunas de seguimiento y cuellos de botella en el cobro debilitan la recuperación de costes y los ingresos institucionales."
      }
    ]
  },
  "capabilities": {
    "eyebrow": "Capacidades de la plataforma",
    "title": "Capacidades esenciales para la gestión del agua",
    "subtitle": "Uma base de dados centralizada partilhada entre departamentos.",
    "tabListLabel": "Capacidades de la plataforma",
    "panelLabel": "Detalle de capacidad",
    "items": [
      {
        "icon": "registry",
        "title": "Registro estandarizado",
        "description": "Procedimientos unificados para registrar usuarios del agua y emitir permisos, alineados con las normas y circuitos de aprobación de su autoridad.",
        "image": "/images/SIRH_screenshot_procedure.webp",
        "imageAlt": "Pantalla de registro de usuarios y permisos en SIRH",
        "imageFit": "cover",
        "imageSizeHint": "Recomendado 960×540 px"
      },
      {
        "icon": "gis",
        "title": "Cartografía georreferenciada",
        "description": "Registre y visualice ámbitos de explotación, cultivos y puntos de captación o vertido en mapas interactivos vinculados a los permisos.",
        "image": "/images/SIRH_screenshot_map_detail.webp",
        "imageAlt": "Mapa georreferenciado de ámbitos de explotación en SIRH",
        "imageFit": "cover",
        "imageSizeHint": "Recomendado 960×540 px"
      },
      {
        "icon": "estimation",
        "title": "Estimación automatizada",
        "description": "Aplique valores de referencia institucionales para calcular el consumo de agua automáticamente, sustituyendo estimaciones manuales en renovaciones y ciclos de facturación.",
        "image": "/images/SIRH_screenshot_estimation.webp",
        "imageAlt": "Estimación automatizada de consumo de agua en SIRH",
        "imageFit": "cover",
        "imageSizeHint": "Recomendado 960×540 px"
      },
      {
        "icon": "workflow",
        "title": "Seguimiento de solicitudes y renovaciones",
        "description": "Supervise solicitudes y renovaciones de permisos en cada paso institucional, con estado claro para el personal y los responsables.",
        "image": "/images/SIRH_screenshot_procedures.webp",
        "imageAlt": "Flujo de solicitudes y renovaciones de permisos en SIRH",
        "imageFit": "cover",
        "imageSizeHint": "Recomendado 960×540 px"
      },
      {
        "icon": "document",
        "title": "Generación de documentos e informes",
        "description": "Genere permisos oficiales, facturas e informes operativos bajo demanda. Exporte a PDF, Excel o formatos geoespaciales cuando los equipos necesiten compartir o analizar datos fuera del sistema.",
        "image": "/images/SIRH_from_screen_to_print.webp",
        "imageAlt": "Generación de documentos e informes en SIRH",
        "imageFit": "contain",
        "imageSizeHint": "Recomendado 800×600 px"
      },
      {
        "icon": "billing",
        "title": "Facturación y recuperación de costes",
        "description": "Automatice la generación de facturas, procese lotes por cuenca o ciclo de facturación y haga seguimiento de pagos y saldos pendientes en un solo lugar.",
        "image": "/images/SIRH_screenshot_invoices.webp",
        "imageAlt": "Módulo de facturación y recuperación de costes en SIRH",
        "imageFit": "cover",
        "imageSizeHint": "Recomendado 960×540 px"
      }
    ]
  },
