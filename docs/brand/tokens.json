{
  "$description": "Exportación semántica portable de la identidad SIRH (agnóstica de stack, formato inspirado en W3C Design Tokens). En este repositorio (landing comercial) los valores se sincronizan desde templates/layout.html: primary, secondary y neutral. Los roles color.accent y color.domain.* se conservan como referencia de la aplicación SIRH interna (tema MUI).",
  "color": {
    "primary": {
      "main": {
        "$value": "#00bec5",
        "$type": "color",
        "$description": "CTAs, acentos de marca, focus rings"
      },
      "light": {
        "$value": "#ccfbf1",
        "$type": "color",
        "$description": "Selección de texto, bordes suaves de marca"
      },
      "lighter": {
        "$value": "#f0fdfa",
        "$type": "color",
        "$description": "Badges, contenedores de icono"
      },
      "dark": {
        "$value": "#1ba7ba",
        "$type": "color",
        "$description": "Hover de CTAs y enlaces"
      },
      "contrastText": { "$value": "#ffffff", "$type": "color" }
    },
    "secondary": {
      "main": {
        "$value": "#52684b",
        "$type": "color",
        "$description": "Acento alternativo (p. ej. énfasis distinto al primario)"
      },
      "light": { "$value": "#a3af9e", "$type": "color" },
      "lighter": { "$value": "#d7ddd5", "$type": "color" },
      "dark": { "$value": "#3f4a3c", "$type": "color" }
    },
    "neutral": {
      "0": { "$value": "#ffffff", "$type": "color" },
      "50": {
        "$value": "#f8fafc",
        "$type": "color",
        "$description": "Fondo de página y secciones alternas"
      },
      "100": {
        "$value": "#f1f5f9",
        "$type": "color",
        "$description": "Superficies hundidas y bordes suaves"
      },
      "200": {
        "$value": "#e2e8f0",
        "$type": "color",
        "$description": "Bordes y divisores"
      },
      "300": {
        "$value": "#cbd5e1",
        "$type": "color",
        "$description": "Decoración e iconos atenuados"
      },
      "400": {
        "$value": "#94a3b8",
        "$type": "color",
        "$description": "Texto terciario, eyebrows"
      },
      "500": {
        "$value": "#64748b",
        "$type": "color",
        "$description": "Texto cuaternario, notas al pie"
      },
      "600": {
        "$value": "#475569",
        "$type": "color",
        "$description": "Texto secundario, navegación"
      },
      "700": {
        "$value": "#334155",
        "$type": "color",
        "$description": "Texto enfatizado, bordes sobre fondo oscuro"
      },
      "800": {
        "$value": "#1e293b",
        "$type": "color",
        "$description": "Capas elevadas sobre fondo oscuro"
      },
      "900": {
        "$value": "#383836",
        "$type": "color",
        "$description": "Texto principal y fondos oscuros"
      }
    },
    "accent": {
      "main": {
        "$value": "#7a5d44",
        "$type": "color",
        "$description": "App SIRH (MUI); en la landing usar secondary como acento alternativo"
      },
      "light": { "$value": "#a98a72", "$type": "color" },
      "lighter": { "$value": "#d3bcae", "$type": "color" },
      "dark": { "$value": "#4c3727", "$type": "color" },
      "contrastText": { "$value": "#1e120c", "$type": "color" }
    }
  },
  "typography": {
    "fontFamily": {
      "base": {
        "$value": "Inter",
        "$type": "fontFamily",
        "$description": "Landing comercial; app SIRH usa Roboto"
      }
    },
    "fontSize": {
      "base": {
        "$value": "16px",
        "$type": "dimension",
        "$description": "Tailwind text-base por defecto"
      }
    }
  },
  "spacing": {
    "unit": { "$value": "8px", "$type": "dimension" },
    "pagePadding": {
      "$value": "16px",
      "$type": "dimension",
      "$description": "px-4 en contenedor principal"
    },
    "sectionPaddingY": {
      "$value": "80px",
      "$type": "dimension",
      "$description": "py-20 entre secciones del scroll"
    }
  },
  "shape": {
    "borderRadius": {
      "button": {
        "$value": "6px",
        "$type": "dimension",
        "$description": "rounded-md en CTAs"
      },
      "card": {
        "$value": "8px",
        "$type": "dimension",
        "$description": "rounded-lg en cards estándar"
      },
      "cardElevated": {
        "$value": "12px",
        "$type": "dimension",
        "$description": "rounded-xl en bloques complejos y banners"
      },
      "pill": {
        "$value": "9999px",
        "$type": "dimension",
        "$description": "rounded-full en badges hero"
      }
    }
  }
}
